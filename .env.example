POSTGRES_DB=inutriguide
POSTGRES_USER=inutriguide
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://inutriguide:change_me@postgres:5432/inutriguide
REDIS_URL=redis://redis:6379/0

DJANGO_SECRET_KEY=change_me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api.localhost,backend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081,http://127.0.0.1:8081
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
RECOMMENDER_ARTIFACT_DIR=/app/storage/recommender
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_TIMEOUT_SECONDS=20
CHAT_MAX_INPUT_CHARS=1200
CHAT_RATE_LIMIT_PER_MINUTE=20

API_BASE_URL=http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_API_BASE_URL=http://YOUR_LOCAL_IP:8000/api/v1
EXPO_PORT=8081
# Optional: set this to your computer's LAN IP when using Expo Go from a phone via Docker.
REACT_NATIVE_PACKAGER_HOSTNAME=

TRAEFIK_DASHBOARD_AUTH=admin:hashed_password_here
TRAEFIK_ACME_EMAIL=ops@example.com
DOZZLE_AUTH_PROVIDER=simple
DOZZLE_BASIC_AUTH=admin:$$apr1$$replace$$with-real-htpasswd-hash

API_DOMAIN=api.localhost
ADMIN_DOMAIN=admin.localhost
LOGS_DOMAIN=logs.localhost

POSTGRES_DB=inutriguide
POSTGRES_USER=inutriguide
POSTGRES_PASSWORD=replace_with_strong_database_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace_with_strong_neo4j_password

REDIS_URL=redis://redis:6379/0

DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=replace_with_long_random_secret
DJANGO_DEBUG=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_ALLOWED_HOSTS=34.155.56.156,backend,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://34.155.56.156
CSRF_TRUSTED_ORIGINS=http://34.155.56.156
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192
GROQ_TIMEOUT_SECONDS=20
CHAT_MAX_INPUT_CHARS=1200
CHAT_RATE_LIMIT_PER_MINUTE=20

PUBLIC_HOST=34.155.56.156
LOGS_HOST=logs.34.155.56.156.nip.io
VITE_API_BASE_URL=http://34.155.56.156/api/v1
EXPO_PUBLIC_API_BASE_URL=http://34.155.56.156/api/v1
TRAEFIK_ACME_EMAIL=ops@example.com

DOCKER_IMAGE_NAMESPACE=wakilriah
IMAGE_TAG=latest
DOCKER_PLATFORM=linux/amd64

ADMIN_EMAIL=admin@example.com
ADMIN_NAME=I-NutriGuide Admin
ADMIN_PASSWORD=replace_with_strong_admin_password

# Generate with: htpasswd -nb admin "your-password"
# Escape each $ as $$ when stored in a Compose env file.
DOZZLE_BASIC_AUTH=admin:$$apr1$$replace$$with-real-htpasswd-hash
